{
  "name": "@healthcheckwrangler/hcw",
  "version": "2.0.0",
  "description": "Playwright + Lighthouse site monitoring with TimescaleDB.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HealthcheckWrangler/healthcheck-wrangler"
  },
  "bin": {
    "hcw": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/",
    "config.yaml.example",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ui": "vite build --config src/dashboard/ui/vite.config.ts",
    "build:all": "npm run build && npm run build:ui",
    "start": "node --enable-source-maps dist/src/index.js",
    "start:dashboard": "node --enable-source-maps dist/src/dashboard/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:ui": "vite --config src/dashboard/ui/vite.config.ts",
    "hcw": "tsx src/cli/index.ts",
"typecheck": "tsc -p tsconfig.json --noEmit",
    "release": "release-it",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "lighthouse": "^12.2.1",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "1.59.1",
    "postgres": "^3.4.9",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "date-fns": "^4.1.0",
    "husky": "^9.1.7",
    "lucide-react": "^1.11.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "release-it": "^20.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.10"
  }
}
