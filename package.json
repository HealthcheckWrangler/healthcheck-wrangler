{
  "name": "@healthcheckwrangler/hcw",
  "version": "0.1.0",
  "description": "Playwright + Lighthouse site monitoring with Prometheus metrics.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hcw": "./dist/src/cli/index.js",
    "hcw-alerting-push": "./dist/scripts/sync-alerting.js",
    "hcw-dashboards-push": "./dist/scripts/sync-dashboards.js"
  },
  "files": [
    "dist/",
    "config.yaml.example",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "hcw": "tsx src/cli/index.ts",
    "dashboards:push": "tsx --env-file=.env scripts/sync-dashboards.ts",
    "alerting:push": "tsx --env-file=.env scripts/sync-alerting.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "dotenv": "^16.4.5",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "lighthouse": "^12.2.1",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "1.59.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
