{
  "title": "Improntad Healthchecks — Site Detail",
  "uid": "improntad-site-detail",
  "tags": ["improntad", "healthchecks"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-72h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "site",
        "label": "Site",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(healthcheck_up, site)", "refId": "Prometheus" },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pages up right now",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(healthcheck_up{site=\"$site\"} and on(site,page) (time() - healthcheck_last_run_seconds{site=\"$site\"} < 1200))", "legendFormat": "up" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Availability (7d)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(avg_over_time(healthcheck_up{site=\"$site\"}[7d])) * 100"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Alerting",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "site_alerting_enabled{site=\"$site\"}" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OPTED OUT", "color": "orange", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "ENABLED", "color": "green", "index": 1 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "state-timeline",
      "title": "Page status timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "healthcheck_up{site=\"$site\"} and on(site,page) (time() - healthcheck_last_run_seconds{site=\"$site\"} < 1200)",
          "legendFormat": "{{page}}"
        }
      ],
      "options": { "mergeValues": false, "showValue": "never", "rowHeight": 0.9 },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 1 } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Check duration (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "healthcheck_duration_seconds{site=\"$site\"}",
          "legendFormat": "{{page}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineInterpolation": "smooth" } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Failed selectors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "healthcheck_selectors_failed{site=\"$site\"}",
          "legendFormat": "{{page}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Lighthouse — Performance (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(lighthouse_score{site=\"$site\", category=\"performance\"})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "Accessibility (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(lighthouse_score{site=\"$site\", category=\"accessibility\"})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Best Practices (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(lighthouse_score{site=\"$site\", category=\"best_practices\"})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "SEO (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "avg(lighthouse_score{site=\"$site\", category=\"seo\"})" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Performance score over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "lighthouse_score{site=\"$site\", category=\"performance\"}",
          "legendFormat": "{{page}}"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "none" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Core Web Vitals over time (LCP / FCP / TBT)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(lighthouse_lcp_seconds{site=\"$site\"})",
          "legendFormat": "LCP"
        },
        {
          "refId": "B",
          "expr": "avg(lighthouse_fcp_seconds{site=\"$site\"})",
          "legendFormat": "FCP"
        },
        {
          "refId": "C",
          "expr": "avg(lighthouse_tbt_seconds{site=\"$site\"})",
          "legendFormat": "TBT"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
