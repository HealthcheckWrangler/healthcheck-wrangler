# ── Grafana Cloud (required for grafana-cloud mode only) ──────────────────────
# Your Grafana Cloud stack URL. Found in Grafana Cloud portal → your stack → Details.
GRAFANA_CLOUD_URL=https://your-stack.grafana.net

# Grafana Cloud API token with Editor role.
# Create at: your-stack.grafana.net → Administration → Service accounts
GRAFANA_CLOUD_API_TOKEN=glsa_...

# Prometheus remote_write endpoint. Found in Grafana Cloud → Prometheus → Details.
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-region.grafana.net/api/prom/push

# Prometheus remote_write credentials (username is numeric, password is a token).
GRAFANA_CLOUD_PROM_USERNAME=123456
GRAFANA_CLOUD_PROM_PASSWORD=glc_...

# ── PagerDuty (optional — required only if alerting is enabled) ───────────────
# Events API v2 integration key. Create a new integration in PagerDuty →
# Services → your service → Integrations → Add integration → Events API v2.
PAGERDUTY_INTEGRATION_KEY=

# ── Project identity ──────────────────────────────────────────────────────────
# Used by Alloy as the Prometheus job label. Must match project.name in config.yaml.
# Alloy reads env vars directly and cannot read config.yaml, so this is required separately.
HCW_PROJECT_NAME=my-healthchecks

# ── Lighthouse reports (optional) ────────────────────────────────────────────
# If set, Lighthouse HTML reports are auto-committed to a remote git repo (e.g. GitHub Pages).
# Leave blank to keep reports local only.
REPORTS_GIT_REMOTE=
REPORTS_GIT_BRANCH=main
