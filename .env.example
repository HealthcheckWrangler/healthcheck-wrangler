# Grafana Cloud — required by Alloy (reads via sys.env()) and sync scripts
GRAFANA_CLOUD_URL=https://your-stack.grafana.net
GRAFANA_CLOUD_API_TOKEN=glsa_...
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-region.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=123456
GRAFANA_CLOUD_PROM_PASSWORD=glc_...

# PagerDuty — Events API v2 integration key
PAGERDUTY_INTEGRATION_KEY=

# Project identity — used by Alloy job label (Alloy cannot read config.yaml)
HCW_PROJECT_NAME=my-healthchecks

# Optional: auto-commit Lighthouse reports to a GitHub Pages repo
REPORTS_GIT_REMOTE=
REPORTS_GIT_BRANCH=main
