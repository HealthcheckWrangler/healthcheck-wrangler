# ── Database (required) ───────────────────────────────────────────────────────
# Password for the TimescaleDB postgres user.
# The full DATABASE_URL is constructed in docker-compose.yml using this value.
DB_PASSWORD=change_me

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Expose the dashboard externally without port forwarding or a static IP.
# Create a tunnel at dash.cloudflare.com → Zero Trust → Networks → Tunnels.
# CLOUDFLARE_TUNNEL_TOKEN=
