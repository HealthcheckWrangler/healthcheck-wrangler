project:
  name: my-healthchecks        # used in User-Agent string

runner:
  workers: 3                   # number of sites checked concurrently
  pageDelayMs: 0               # ms to wait between page requests within a site (0 = disabled)
  sitesDir: ./sites            # directory containing site YAML files
  reportsDir: ./reports        # directory where Lighthouse HTML/JSON report files are saved
  logLevel: info               # trace | debug | info | warn | error | fatal
  schedulerTickMs: 1000        # how often the scheduler checks for due tasks (ms)
  lighthouseStartDelayMs: 30000  # delay before the first Lighthouse run after startup (ms)

  # Dashboard API — set apiPort: 0 to disable
  apiPort: 8080                # port for the runner's internal REST + SSE API

  # Retention (requires DATABASE_URL env var to be set)
  logRetentionDays: 7          # log entries older than this are dropped automatically by TimescaleDB
  resultsRetentionDays: 180    # healthcheck + lighthouse result history retention (6 months)
  lighthouseReportRetentionDays: 7  # delete Lighthouse HTML/JSON report files from disk after N days

healthcheck:
  defaultIntervalMinutes: 10   # how often to run healthchecks (per-site YAML can override)
  defaultTimeoutSeconds: 30    # page navigation timeout
  selectorTimeoutMs: 5000      # per-selector visibility check timeout
  forceCloseTimeoutMs: 5000    # browser force-close timeout on error

lighthouse:
  defaultIntervalMinutes: 360  # how often to run Lighthouse audits (6 hours)
  defaultThrottling: mobile    # mobile | desktop
  desktopWidth: 1350
  desktopHeight: 940
  forceCloseTimeoutMs: 5000

watcher:
  stabilityThreshold: 250      # ms a site YAML must be stable before reloading
  pollInterval: 50             # chokidar poll interval (ms)

alerting:
  # Native channel-based alerting — fires on state transitions (up→down, down→up)
  channels:
    - type: google-chat
      name: Ops              # optional label for logs
      webhookUrl: "https://chat.googleapis.com/v1/spaces/SPACE/messages?key=KEY&token=TOKEN"
      on:                    # events to send — omit the list to receive all
        - site-down
        - site-recovery
        - high-memory        # RAM > 85%
        - memory-recovered
        - high-load          # CPU load > 90% of core count
        - load-recovered
  # Uncomment to add more channels, e.g. a separate space for critical alerts only:
  # - type: google-chat
  #   name: Critical
  #   webhookUrl: "https://chat.googleapis.com/..."
  #   on: [site-down]
